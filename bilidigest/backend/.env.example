# === LLM配置 ===
LLM_API_KEY=在此填入您的API Key
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=MiniMax-Text-01
# 可替换为其他 OpenAI 兼容接口：
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# === 应用配置 ===
DATA_DIR=../data
MAX_VIDEO_DURATION=14400
MAX_PROCESS_DURATION=7200

# === 开发配置 ===
BACKEND_PORT=8000
FRONTEND_PORT=3000
DEBUG=true
